{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "执行块（酶/工具/动作的标准化接口）",
  "description": "每个酶、工具、动作的最小执行单元，必须符合此接口",
  "type": "object",
  "required": ["id", "name", "type", "inputs", "outputs"],
  "properties": {
    "id": {"type": "string", "description": "唯一标识，如 block:enzyme-e1"},
    "name": {"type": "string"},
    "type": {"type": "string", "enum": ["enzyme", "tool", "action", "probe"]},
    "version": {"type": "string"},
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string", "enum": ["json", "string", "number", "boolean", "float"]},
          "default": {},
          "required": {"type": "boolean", "default": false}
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    },
    "config": {
      "type": "object",
      "description": "自由扩展的配置项",
      "additionalProperties": true
    }
  }
}
