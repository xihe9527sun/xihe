    {
      "id": "arxiv-2607.03734",
      "name": "GRASP: Graph-Reasoning Aided Survey Planning for High-Fidelity Related Work Generation",
      "dir": "arxiv-2607.03734/",
      "source": "arXiv:cs.CL:2607.03734",
      "status": "digested",
      "added_at": "2026-07-18T12:30:00.939535+08:00",
      "digested_at": "2026-07-18T12:30:00.939535+08:00",
      "tags": [
        "cognitive architecture",
        "long context"
      ],
      "score": 0.78,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.03734",
      "snippet": "撰写文献综述需要深入理解被引论文之间的关系：它们如何互相构建、挑战或提供替代视角。我们提出图推理辅助调查规划(GRASP)，一个将LLM规划用于相关工作生成与图算法相结合的框架，以提取被引论文之间的关键关系。我们的双层图结构由一个思维图和一个论点-反论点规划网络组成，在不同粒度上表示被引论文，并且我们通过Steiner树应用拓扑感知剪枝以识别图中捕获的核心论文间关系。我们基于引文分析的评估表明，在引用的语篇角色、意图和分组方面，GRASP生成的相关工作部分与人工撰写的目标非常匹配。"
    },
    {
      "id": "arxiv-2607.00019",
      "name": "CoC-Seduce: Assessing Rule Adherence in Semi-Open Textual Sandboxes",
      "dir": "arxiv-2607.00019/",
      "source": "arXiv:cs.CL",
      "status": "digested",
      "added_at": "2026-07-18T12:30:00.978947+08:00",
      "digested_at": "2026-07-18T12:30:00.978947+08:00",
      "tags": [
        "multi-agent"
      ],
      "score": 0.6,
      "hebbian_credit": 6,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.00019",
      "snippet": "LLMs deployed as autonomous adjudicators in semi-open textual game environments face rule adherence challenges. We present CoC-Seduce, a multi-agent adversarial benchmark built on TRPG mechanics that tests vulnerability to Rhetorical Injection attacks where adversarial users exploit narrative framing techniques to bypass adjudication logic."
    },
    {
      "id": "arxiv-2607.00110",
      "name": "CoopEval: Benchmarking Cooperation-Sustaining Mechanisms and LLM Agents in Social Dilemmas",
      "dir": "arxiv-2607.00110/",
      "source": "arXiv:cs.MA",
      "status": "digested",
      "added_at": "2026-07-18T12:30:01.004611+08:00",
      "digested_at": "2026-07-18T12:30:01.004611+08:00",
      "tags": [
        "multi-agent",
        "catalyst"
      ],
      "score": 0.72,
      "hebbian_credit": 7,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.00110",
      "snippet": "LLM agents increasingly need to interact effectively with other goal-pursuing agents, yet LLMs with stronger reasoning behave less cooperatively. We present the first comparative study of game-theoretic mechanisms for enabling cooperative outcomes. Found that contracting and mediation are most effective in achieving cooperative outcomes between capable LLM models."
    },
    {
      "id": "arxiv-2607.02686",
      "name": "ASK in the Dark: Uncertainty-Gated LLM Assistance under Partial Observability",
