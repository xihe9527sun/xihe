      "tags": [
        "multi-agent"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.11250",
      "snippet": "Exploration is essential for reliable autonomy in multi-agent systems yet it remains unclear whether LLM agents can explore effectively when interacting. We show that modern LLM agents fail to do so exhibiting myopic and polarized interaction patterns."
    },
    {
      "id": "arxiv-2607.09766",
      "name": "Norm Enforcement for AI Agents: Robustly Shaping Behavior in Multi-Agent Systems",
      "dir": "arxiv-2607.09766/",
