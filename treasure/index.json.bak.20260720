        "autonomous-agent"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.09748",
      "snippet": "In distributed systems, the classical State Machine Replication (SMR) model assumes deterministic transitions. The rise of agentic distributed systems where autonomous, stochastic, and model-driven agents orchestrate infrastructure presents scenarios where deterministic bitwise replication is insufficient."
    },
    {
      "id": "arxiv-2607.09803",
      "name": "Spectral Origins of the Self-Correction Blind Spot in Autoregressive Generation",
      "dir": "arxiv-2607.09803/",
      "source": "arXiv:cs.LG:2607.09803",
      "status": "digested",
      "added_at": "2026-07-18T12:30:05.699725+08:00",
