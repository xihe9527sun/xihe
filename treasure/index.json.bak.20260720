        "autonomous-agent"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.10059",
      "snippet": "Agent systems based on large language models are increasingly deployed for autonomous tasks yet existing evaluations mostly focus on task success rather than whether agents know when to abstain. This gap poses real risks under ambiguity conflicting constraints or tool failures."
    },
    {
      "id": "arxiv-2607.11707",
      "name": "An Explainable Agentic System for Detection of Conversational Scams with Summary-Based Memory",
      "dir": "arxiv-2607.11707/",
