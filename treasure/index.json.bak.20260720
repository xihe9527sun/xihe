      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.10034",
      "snippet": "Large language models store factual knowledge in their parameters. While recent work shows this knowledge resides in MLP layers existing constructive and mechanistic interpretability models fail to explain the surprising empirical phenomenon that facts are stored at an information-theoretically optimal rate."
    },
    {
      "id": "arxiv-2607.10645",
      "name": "MafiaScope: Non-Invasive Time-Resolved Belief Probing for LLM Agents in Social Deduction Games",
      "dir": "arxiv-2607.10645/",
