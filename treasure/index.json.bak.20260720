      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.10811",
      "snippet": "AI engineering is shifting from passive text generation to agent-driven task execution creating new reliability challenges. We propose Distributed Agent System (DAS) a device-edge-cloud framework for fault-tolerant collaboration among heterogeneous agents."
    },
    {
      "id": "arxiv-2607.09773",
      "name": "EvoCUA-1.5: Online Reinforcement Learning for Multi-turn Computer-Use Agents",
      "dir": "arxiv-2607.09773/",
