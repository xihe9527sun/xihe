      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.09921",
      "snippet": "We study a setting that requires long-context reasoning over hundreds of pages of technical documents for merger arbitrage. Our system combines expert-guided context engineering with finetuning on hindsight-guided reasoning traces derived from historical deals."
    },
    {
      "id": "arxiv-2607.09765",
      "name": "How Much Does Correctness Cost? Budgeted Placement of Strong Correctors in a Weak Multi-Agent Swarm",
      "dir": "arxiv-2607.09765/",
