      "tags": [
        "multi-agent"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.ma.new2",
      "snippet": "A delay-aware, uncertainty-driven multi-agent reinforcement learning framework for counter-UAV target localization using active triangulation. Age-of-Information enhanced observations improve triangulation efficacy by 10.6 percentage points. Perception-consistent reward outperforms privileged clean-state rewards with RMSE 0.547m versus 0.633m."
    },
    {
      "id": "information-limits-and-attractor-dynamics-in-econo",
      "name": "Information Limits and Attractor Dynamics in Economies of Frontier LLM Agents",
      "dir": "information-limits-and-attractor-dynamics-in-econo/",
      "source": "arXiv:cs.MA:2607.new",
      "status": "digested",
      "added_at": "2026-07-18T12:30:01.775488+08:00",
