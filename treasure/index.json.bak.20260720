      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.09773",
      "snippet": "Computer-use agents must solve long-horizon tasks through repeated interaction with partially observable multimodal desktop environments. Although imitation learning and offline trajectory refinement provide strong priors static traces cannot cover the causal feedback loop of real computer use."
    },
    {
      "id": "arxiv-2607.09711",
      "name": "EvoClawBench: Can Agents Learn Reusable Skills from Their Own Runs?",
      "dir": "arxiv-2607.09711/",
