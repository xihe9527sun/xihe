        "memory"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.11707",
      "snippet": "Conversational scams span multiple weeks gradually build trust. Existing scam-detection focuses on isolated messages. We present an explainable agentic system with summary-based memory for detecting sophisticated conversational scams."
    },
    {
      "id": "arxiv-2602.04291",
      "name": "Disentangling Intrinsic Importance from Emergent Structure in Multi-Expert Orchestration",
      "dir": "arxiv-2602.04291/",
