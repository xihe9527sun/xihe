        "counterfactual"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.10645",
      "snippet": "We present MafiaScope an open testbed that turns the social deduction game Mafia into a measurement instrument for machine Theory of Mind. After every public utterance every agent privately answers probe questions with counterfactual replay forking any recorded step."
    },
    {
      "id": "arxiv-2607.11250",
      "name": "Multi-Agent LLMs Fail to Explore Each Other",
      "dir": "arxiv-2607.11250/",
      "source": "arXiv:cs.MA:2607.11250",
      "status": "digested",
      "added_at": "2026-07-18T12:30:05.449749+08:00",
