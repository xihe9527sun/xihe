      "tags": [
        "self-reflection"
      ],
      "score": 0.75,
      "hebbian_credit": 8,
      "layer": "L8",
      "url": "https://arxiv.org/abs/2607.09803",
      "snippet": "Large autoregressive language models exhibit a self-correction blind spot: they reliably fix identical errors when attributed to an external source yet fail to fix the same errors in their own outputs. We offer a formal model of why generating a token suppresses error detection."
    },
    {
      "id": "arxiv-2607.09685",
      "name": "Transfer Learning Across Policy Regimes in Adaptive Multi-Agent Systems",
      "dir": "arxiv-2607.09685/",
      "source": "arXiv:cs.MA:2607.09685",
