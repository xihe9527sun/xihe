{
  "id": "block:web_search",
  "name": "网页搜索",
  "type": "tool",
  "inputs": [
    {
      "name": "query",
      "type": "string",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "results",
      "type": "json"
    }
  ],
  "config": {
    "max_results": 5,
    "timeout": 10
  }
}